{
    "name": "letkode/common-bundle",
    "description": "Common exceptions, attributes, value resolvers and utilities for Symfony applications",
    "type": "symfony-bundle",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "doctrine/persistence": "^3.0",
        "letkode/helpers-bundle": "^1.0",
        "symfony/http-foundation": "^7.0 || ^8.0",
        "symfony/http-kernel": "^7.0 || ^8.0",
        "symfony/uid": "^7.0 || ^8.0",
        "symfony/translation-contracts": "^3.0",
        "symfony/validator": "^7.0 || ^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11",
        "phpstan/phpstan": "^2",
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "autoload": {
        "psr-4": {
            "Letkode\\CommonBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Letkode\\CommonBundle\\Tests\\": "tests/"
        }
    },
    "extra": {
        "symfony": {
            "bundles": {
                "Letkode\\CommonBundle\\LetkodeCommonBundle": ["all"]
            }
        }
    }
}
